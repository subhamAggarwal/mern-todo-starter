{
    "name": "mern-todo-starter",
    "version": "1.0.0",
    "private": true,
    "description": "MERN-stack Todo app starter for the IDE assessment",
    "main": "server/src/index.js",
    "scripts": {
        "start": "concurrently -n server,client -c blue,green \"npm:start:server\" \"npm:start:client\"",
        "start:server": "node server/src/index.js",
        "start:client": "vite client --host 0.0.0.0 --port 5173",
        "build:client": "vite build client",
        "test": "jest",
        "test:watch": "jest --watch",
        "prefetch:mongo": "node -e \"require('mongodb-memory-server').MongoMemoryServer.create().then(s=>s.stop()).then(()=>console.log('mongo binary cached'))\""
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.19.2",
        "mongoose": "^8.5.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@babel/plugin-syntax-import-meta": "^7.10.4",
        "@babel/preset-env": "^7.29.5",
        "@babel/preset-react": "^7.28.5",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@vitejs/plugin-react": "^4.3.1",
        "babel-jest": "^29.7.0",
        "concurrently": "^8.2.2",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "mongodb-memory-server": "^9.4.0",
        "msw": "^2.14.5",
        "supertest": "^7.0.0",
        "vite": "^5.4.2"
    },
    "jest": {
        "testTimeout": 30000,
        "projects": [
            {
                "displayName": "backend",
                "testEnvironment": "node",
                "testMatch": [
                    "<rootDir>/server/tests/**/*.test.js"
                ]
            },
            {
                "displayName": "frontend",
                "testEnvironment": "<rootDir>/client/src/test/jsdom-fetch-environment.js",
                "testMatch": [
                    "<rootDir>/client/src/**/*.test.jsx"
                ],
                "setupFilesAfterEnv": [
                    "<rootDir>/client/src/test/setup.js"
                ],
                "transform": {
                    "^.+\\.(js|jsx|mjs)$": "babel-jest"
                },
                "transformIgnorePatterns": [
                    "node_modules/(?!(rettime|msw|@mswjs|@open-draft|is-node-process|outvariant|strict-event-emitter|headers-polyfill|@bundled-es-modules|until-async)/)"
                ],
                "moduleNameMapper": {
                    "^msw/node$": "<rootDir>/node_modules/msw/lib/node/index.js",
                    "\\.(css|less|scss|sass)$": "identity-obj-proxy"
                }
            }
        ]
    }
}
