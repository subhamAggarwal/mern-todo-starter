{
    "name": "mern-todo-starter",
    "version": "1.0.0",
    "private": true,
    "description": "MERN-stack Todo app starter for the IDE assessment",
    "main": "server/src/index.js",
    "scripts": {
        "start": "concurrently -n server,client -c blue,green \"npm:start:server\" \"npm:start:client\"",
        "start:server": "node server/src/index.js",
        "start:client": "vite --root client --host 0.0.0.0 --port 5173",
        "build:client": "vite build --root client",
        "test": "jest",
        "test:watch": "jest --watch",
        "prefetch:mongo": "node -e \"require('mongodb-memory-server').MongoMemoryServer.create().then(s=>s.stop()).then(()=>console.log('mongo binary cached'))\""
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.19.2",
        "mongoose": "^8.5.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^4.3.1",
        "concurrently": "^8.2.2",
        "jest": "^29.7.0",
        "mongodb-memory-server": "^9.4.0",
        "supertest": "^7.0.0",
        "vite": "^5.4.2"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": ["<rootDir>/server/tests/**/*.test.js"],
        "testTimeout": 30000
    }
}
